
APP_ENV=development
APP_API_KEY=
ENABLE_USER_AUTH=true
AUTH_TOKEN_TTL_HOURS=24
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_DEMO_MODE=false
DEMO_MAX_UPLOAD_MB=5
DEMO_MAX_PAGES=20
DEMO_MAX_FILES_PER_REQUEST=2
DEMO_MAX_DOCS_PER_SESSION=3
DEMO_UPLOADS_PER_HOUR=3
DEMO_QUERIES_PER_HOUR=30
DEMO_UPLOADS_PER_HOUR_IP=10
DEMO_QUERIES_PER_HOUR_IP=120
DEMO_DOC_TTL_HOURS=24

EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DEVICE=cpu
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=25
RETRIEVAL_TOP_N=6
RETRIEVAL_INITIAL_TOP_K=40
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATE_K=10
BM25_TOP_K=30
MAX_CONTEXT_CHARACTERS=6000
RETRIEVAL_LOW_CONFIDENCE_THRESHOLD=0.30
ANSWER_LOW_CONFIDENCE_THRESHOLD=0.22
ENABLE_RETRIEVAL_FALLBACK=true
ENABLE_RETRIEVAL_DIAGNOSTICS=true
ENABLE_NEURAL_RERANKER=false
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_BATCH_SIZE=16
RERANKER_USE_FP16=false
RERANK_TOP_K=10
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL_SECONDS=600
ENABLE_DOCLING=false
ENABLE_OCR=false
DOCLING_BATCH_SIZE=10
ENABLE_VISION_ENRICHMENT=false
MAX_VISION_CALLS_PER_DOC=10
OPENAI_VISION_MODEL=gpt-4.1-mini
LOCAL_VISION_ENDPOINT=http://localhost:11434/api/chat
LOCAL_VISION_MODEL=
ENABLE_METADATA_ENRICHMENT=true
ENABLE_SUMMARY=false
SUMMARY_MAX_TOKENS=20
SUMMARY_MAX_CHUNKS=30
SUMMARY_MIN_CHARS=300
ENABLE_VERIFICATION=true
VERIFICATION_SIMILARITY_THRESHOLD=0.75
VERIFICATION_MIN_ANSWER_CHARS=80
VERIFICATION_WARNING_SUPPORT_THRESHOLD=0.50
EMBEDDING_BATCH_SIZE=16
EMBEDDING_REQUESTS_PER_MINUTE=90

FAISS_INDEX_PATH=data/faiss_index
METADATA_DB_PATH=data/app_metadata.sqlite3

USE_OPENAI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_TOKENS=320
OPENAI_TEMPERATURE=0.2
